.screen--game {
    justify-content: flex-start;
    padding: 16px;
}

/* ── Top: stats ───────────────────────────────────────────────────────── */
.game__top {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
}

.pstats {
    width: 30%;
    padding: 12px;
    border-radius: 10px;
    background-color: rgb(34, 37, 46);
}

.pstats--right {
    -unity-text-align: upper-right;
}

.pstats__faction {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(235, 237, 242);
}

.pstats__hp {
    font-size: 20px;
    color: rgb(232, 108, 70);
    margin-top: 4px;
}

.pstats__res {
    font-size: 17px;
    color: rgb(200, 205, 215);
    margin-top: 2px;
}

.pstats__status {
    font-size: 14px;
    color: rgb(150, 200, 150);
    margin-top: 4px;
    white-space: normal;
}

.game__banner {
    align-items: center;
    justify-content: center;
    padding-top: 10px;
}

.game__turn {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(245, 246, 250);
}

/* ── Mid: slots ───────────────────────────────────────────────────────── */
.game__mid {
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    flex-grow: 1;
    margin-top: 12px;
}

.slots {
    width: 30%;
}

.slots--right {
    align-items: flex-end;
}

.slot {
    height: 56px;
    margin: 4px 0;
    padding: 8px 12px;
    border-radius: 8px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.06);
    background-color: rgb(44, 48, 60);
    justify-content: center;
    min-width: 200px;
}

.slot--empty {
    background-color: rgba(44, 48, 60, 0.4);
    border-color: rgba(255, 255, 255, 0.03);
}

.slot--target {
    border-color: rgb(232, 108, 70);
}

.slot--target:hover {
    background-color: rgb(60, 65, 80);
}

.slot__name {
    font-size: 15px;
    color: rgb(235, 237, 242);
    -unity-font-style: bold;
}

.slot__meta {
    font-size: 13px;
    color: rgb(170, 176, 188);
}

.game__center {
    width: 20%;
}

/* ── Hand ─────────────────────────────────────────────────────────────── */
.game__hint {
    font-size: 15px;
    color: rgb(220, 200, 120);
    -unity-text-align: middle-center;
    height: 20px;
    margin-bottom: 4px;
}

.hand {
    flex-direction: row;
    justify-content: center;
    margin-top: 8px;
}

.card {
    width: 130px;
    height: 170px;
    margin: 0 5px;
    padding: 8px;
    border-radius: 8px;
    border-width: 2px;
    border-color: rgba(255, 255, 255, 0.08);
    background-color: rgb(48, 52, 66);
    align-items: flex-start;
    justify-content: flex-start;
    transition-duration: 0.08s;
}

.card:hover {
    border-color: rgba(255, 255, 255, 0.4);
}

.card--selected {
    border-color: rgb(232, 108, 70);
    scale: 1.05 1.05;
}

.card--unaffordable {
    opacity: 0.45;
}

.card__name {
    font-size: 15px;
    -unity-font-style: bold;
    color: rgb(240, 242, 247);
    white-space: normal;
}

.card__cost {
    font-size: 14px;
    color: rgb(220, 200, 120);
    margin-top: 4px;
}

.card__body {
    font-size: 12px;
    color: rgb(190, 196, 208);
    white-space: normal;
    margin-top: 6px;
}

.game__actions {
    flex-direction: row;
    justify-content: center;
    margin-top: 10px;
}

.game__actions .btn {
    min-width: 150px;
    margin: 0 8px;
}

/* ── Overlay ──────────────────────────────────────────────────────────── */
.overlay {
    display: none;
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(12, 13, 17, 0.88);
    align-items: center;
    justify-content: center;
}

.overlay__panel {
    align-items: center;
    justify-content: center;
    padding: 32px;
}

.overlay__title {
    font-size: 40px;
    -unity-font-style: bold;
    color: rgb(245, 246, 250);
    margin-bottom: 8px;
}

.overlay__msg {
    font-size: 20px;
    color: rgb(190, 196, 208);
    margin-bottom: 28px;
}
